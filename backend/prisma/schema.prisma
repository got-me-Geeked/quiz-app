// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  username     String   @unique
  createdAt    DateTime @default(now())

  quizzes      Quiz[]
  participations QuizParticipant[]
}

model Quiz {
  id          String   @id @default(uuid())
  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id])
  title       String
  category    String?
  status      String   @default("draft") // draft/waiting/active/finished/cancelled
  roomCode    String?  @unique
  minPlayers  Int      @default(1)
  maxPlayers  Int      @default(50)
  secondsPerQuestion Int
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  questions    Question[]
  participants QuizParticipant[]
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  format        String  //текст / картинка
  answerType    String  //одиночный / множественный
  content       String? //текст вопроса
  imageUrl      String? //заглушка загружки (поле имя файла / null)
  options       Json // [{ id, text }] — всегда есть
  correctAnswer Json //  массив с id правильных вариантов
  orderIndex    Int
}

model QuizParticipant {
  id         String   @id @default(uuid())
  quizId     String
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  score      Int      @default(0)
  finishedAt DateTime?

  answers    Answer[]
  @@unique([quizId, userId])
}

model Answer {
  id                String   @id @default(uuid())
  quizParticipantId String
  participant       QuizParticipant @relation(fields: [quizParticipantId], references: [id])
  questionId        String
  answerValue       Json
  isCorrect         Boolean
  pointsAwarded     Int
  answeredAt        DateTime @default(now())
}